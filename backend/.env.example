# Copy this file to .env and fill in your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# The app defaults to port 8787.
PORT=8787
HOST=0.0.0.0

# Change this on the server if you want to switch models without rebuilding the app.
OPENAI_MODEL=gpt-4.1-mini

# Google Play purchase verification for AI scan packs.
# Create a Play Console API service account with Android Publisher access.
GOOGLE_PLAY_PACKAGE_NAME=se.kvittordning.app
GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=C:\path\to\play-service-account.json

# Optional: move the local credit ledger if you do not want it beside server.js.
# ENTITLEMENTS_FILE=C:\path\to\receiptory-entitlements.json
